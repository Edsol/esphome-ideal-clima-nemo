; Copy this file to secrets.ini and fill in your values.
; secrets.ini is git-ignored and must NOT be committed.
;
; PlatformIO substitutes these into build_flags in platformio.ini via
; ${secrets.<key>}.

[secrets]
wifi_ssid = YOUR_WIFI_SSID
wifi_pass = YOUR_WIFI_PASSWORD
mqtt_host = 192.168.1.10
mqtt_port = 1883
mqtt_user =
mqtt_pass =
